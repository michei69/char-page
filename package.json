    "dotenv": "^17.4.0",
    "elysia": "^1.4.28",
    "lucide-react": "^1.7.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.0.1",
    "react-router": "^7.2.0",
